# --- Database ---
DATABASE_URL=postgresql+asyncpg://ai:ai@db:5432/ai_news
SYNC_DATABASE_URL=postgresql+psycopg2://ai:ai@db:5432/ai_news

# --- OpenAI (required) ---
OPENAI_API_KEY=sk-replace-me
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-4o-mini

# --- YouTube: NO API KEY NEEDED ---
# YT ingestor uses public RSS feeds + transcript-api.

# --- Pipeline tuning ---
DEDUP_THRESHOLD=0.90
CLUSTER_THRESHOLD=0.82
DEDUP_LOOKBACK_DAYS=14
PIPELINE_CRON=0 6 * * *
RETENTION_DAYS=30
RETENTION_CRON=30 6 * * *

# --- Transcript fallback (local Whisper) ---
# Free, CPU-only. Disable in cloud envs without spare CPU minutes.
ENABLE_LOCAL_WHISPER=true
WHISPER_MODEL=base          # tiny | base | small | medium | large-v3
WHISPER_MAX_PER_RUN=15      # cap per pipeline run to bound CPU time

# --- App ---
LOG_LEVEL=INFO
APP_ENV=dev
