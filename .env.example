# --- Database ---
# Needs PostgreSQL with the pgvector extension. For local dev point these at any
# local/remote Postgres (CREATE EXTENSION vector; once). In the cloud these are
# GitHub Actions secrets pointing at Neon — never commit real values.
DATABASE_URL=postgresql+asyncpg://ai:ai@localhost:5432/ai_news
SYNC_DATABASE_URL=postgresql+psycopg2://ai:ai@localhost:5432/ai_news

# --- OpenAI (required) ---
OPENAI_API_KEY=sk-replace-me
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-4o-mini

# --- YouTube: NO API KEY NEEDED ---
# YT ingestor uses public RSS feeds + transcript-api.

# --- Pipeline tuning ---
DEDUP_THRESHOLD=0.90
CLUSTER_THRESHOLD=0.82
DEDUP_LOOKBACK_DAYS=14
PIPELINE_CRON=0 6 * * *
RETENTION_DAYS=30
RETENTION_CRON=30 6 * * *

# --- Audio transcription (videos without subtitles) ---
#   openai → OpenAI transcription API   |   none → disabled
TRANSCRIBE_BACKEND=openai
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe   # or gpt-4o-mini-transcribe | whisper-1
WHISPER_MAX_PER_RUN=15      # cap transcription calls per pipeline run

# --- Telegram delivery (optional) ---
# Daily briefing is sent here at the end of the pipeline. Leave blank to disable.
# Get a token from @BotFather; get chat_id from
#   https://api.telegram.org/bot<TOKEN>/getUpdates  (after messaging your bot).
# Keep these as SECRETS (Windows env / GitHub Actions secrets), not in a committed file.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MAX_ITEMS=12
TELEGRAM_MIN_SCORE=65        # only push stories with boosted score >= this

# --- Weekly email newsletter (optional) ---
# Preferred: Brevo campaign to a contact list (managed unsubscribe + the web form
# feeds this list). Set both BREVO_* + EMAIL_FROM (a verified Brevo sender). In
# Brevo, disable Security → Authorised IPs "for API keys" so Actions can call it.
BREVO_API_KEY=
BREVO_LIST_ID=
# SMTP fallback (used only if BREVO_* is unset). Gmail: smtp.gmail.com + App Password.
# Resend: smtp.resend.com, EMAIL_USER=resend, EMAIL_PASSWORD=<API key>.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=
EMAIL_TO=
EMAIL_MAX_ITEMS=15

# --- LinkedIn drafts (optional) ---
# Ready-to-paste Spanish posts sent to Telegram for manual approval (no LinkedIn API).
LINKEDIN_MIN_SCORE=85               # breaking draft only for boosted score >= this
LINKEDIN_DRAFT_CHAT_ID=             # your DM with the bot; falls back to TELEGRAM_CHAT_ID

# --- App ---
LOG_LEVEL=INFO
APP_ENV=dev
