# Copy this file to ".env.cloud" and paste your Neon connection URLs.
# .env.cloud is gitignored — your DB password never gets committed.
#
# From your Neon connection string:
#   postgresql://USER:PASS@HOST/neondb?sslmode=require&channel_binding=require
# build the two below (drop channel_binding):
DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST/neondb?ssl=require
SYNC_DATABASE_URL=postgresql+psycopg2://USER:PASS@HOST/neondb?sslmode=require
